---
interface Props {
  titleRu: string;
  titleEn: string;
  subtitleRu?: string;
  subtitleEn?: string;
  bgImage?: string;
  overlay?: boolean;
}

const {
  titleRu,
  titleEn,
  subtitleRu,
  subtitleEn,
  bgImage,
  overlay = true,
} = Astro.props;
---

<div class="relative flex items-center justify-center min-h-[40vh] md:min-h-[50vh] overflow-hidden bg-[#1a1a1a]">
  {bgImage && (
    <img src={bgImage} alt={`${titleEn} background`} class="absolute inset-0 w-full h-full object-cover z-0" loading="eager" />
  )}
  {overlay && <div class="absolute inset-0 bg-black/50 z-10"></div>}
  <div class="relative z-20 text-center px-4 max-w-3xl mx-auto py-16">
    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-4 leading-tight">
      <span class="block">{titleRu}</span>
      <span class="block text-2xl md:text-3xl lg:text-4xl text-orange-500 mt-2">{titleEn}</span>
    </h1>
    {(subtitleRu || subtitleEn) && (
      <p class="text-base md:text-lg text-gray-300 max-w-2xl mx-auto">
        {subtitleRu && <span class="block">{subtitleRu}</span>}
        {subtitleEn && <span class="block text-gray-400 text-sm md:text-base mt-1">{subtitleEn}</span>}
      </p>
    )}
    <slot />
  </div>
</div>
