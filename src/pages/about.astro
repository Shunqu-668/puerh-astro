---
import Layout from "../components/Layout.astro";
import CoverHero from "../components/CoverHero.astro";
import CTAButton from "../components/CTAButton.astro";
---

<Layout
  title="О Нас | About Us — Оптовый пуэр из Гуанчжоу с 2006 года"
  description="Два поколения опыта в отборе и поставках пуэра. Прямой путь из Юньнани в ваш город. Two generations of expertise. Direct route from Yunnan to your city."
  ogImage="https://puerhdirect.ru/images/images/about-hero.webp"
  canonicalURL="/about/"
>
  <CoverHero
    titleRu="О нас"
    titleEn="About Us"
    subtitleRu="Два поколения опыта в отборе и поставках пуэра. Прямой путь из Юньнани в ваш город."
    subtitleEn="Two generations of expertise in puerh selection and supply. Direct route from Yunnan to your city."
    bgImage="/images/images/about-hero.webp"
  />

  <!-- Key Facts — structured for AI extraction -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-orange-500">2006</div>
          <p class="text-xs text-gray-500 mt-1">Начало поставок<br/><span class="text-gray-400">Since</span></p>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-500">20+</div>
          <p class="text-xs text-gray-500 mt-1">Лет опыта<br/><span class="text-gray-400">Years Experience</span></p>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-500">500+</div>
          <p class="text-xs text-gray-500 mt-1">Позиций чая<br/><span class="text-gray-400">Tea Products</span></p>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-500">3</div>
          <p class="text-xs text-gray-500 mt-1">Языка поддержки<br/><span class="text-gray-400">Languages: RU/EN/CN</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Yunnan Origin -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <img src="/images/images/about-factory.webp" alt="Yunnan Tea Factory" class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
        <div>
          <h2 class="text-3xl font-bold mb-4">
            <span class="text-gray-900">Наше Производство в Юньнани</span>
            <span class="block text-orange-500 text-xl mt-1">Our Yunnan Origin</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-3">
            <span>Завод нашего дяди в Мэнхай (Сишуанбаньна) и собственные ресурсы в Линьцан (Юндэ) позволяют нам контролировать качество с самого первого листа. Возраст чайных деревьев — от 50 до 500 лет (гушу). Мы работаем напрямую с 12 проверенными семейными хозяйствами. Прямые цены от производителя без скрытых комиссий.</span>
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">
            <span>Our uncle's factory in Menghai (Xishuangbanna) and our own resources in Lincang (Yongde) let us control quality from the very first leaf. Direct factory pricing with no hidden fees.</span>
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <span class="text-xs bg-orange-50 text-orange-600 px-3 py-1 rounded-full font-medium">Сишуанбаньна | Xishuangbanna</span>
            <span class="text-xs bg-orange-50 text-orange-600 px-3 py-1 rounded-full font-medium">Линьцан | Lincang</span>
            <span class="text-xs bg-orange-50 text-orange-600 px-3 py-1 rounded-full font-medium">Пуэр | Pu'er</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Guangzhou Warehouse -->
  <section class="py-16 md:py-24 bg-[#f5f5f5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl font-bold mb-4">
            <span class="text-gray-900">Хаб в Гуанчжоу (Фанцунь)</span>
            <span class="block text-orange-500 text-xl mt-1">Guangzhou Fangcun Hub</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-3">
            <span>Собственный склад в Гуанчжоу, район Фанцунь — крупнейший оптовый чайный рынок Китая. Только опт, отгрузка целыми коробками. Площадь хранения: 500 м². Условия: температура 20-25°C, влажность 65-75% — идеальные параметры для естественной выдержки пуэра. Прямой доступ к международным карго-каналам.</span>
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">
            <span>Our own warehouse in Guangzhou Fangcun — the largest tea wholesale center in China. Wholesale only, shipping by full boxes. Direct access to international cargo channels.</span>
          </p>
        </div>
        <div class="order-1 lg:order-2">
          <img src="/images/images/fangcun-store.webp" alt="Guangzhou Fangcun Warehouse" class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Two Generations -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <img src="/images/images/about-selection.webp" alt="Tea Selection" class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
        <div>
          <h2 class="text-3xl font-bold mb-4">
            <span class="text-gray-900">Два поколения экспертизы</span>
            <span class="block text-orange-500 text-xl mt-1">Two Generations of Expertise</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-3">
            <span>Наша семья занимается чаем с 2006 года — от небольшого магазина в Куньмине до международных поставок. Второе поколение экспертного отбора. За эти годы мы лично посетили более 200 чайных хозяйств в 12 уездах Юньнани, отобрали 12 постоянных поставщиков и собрали коллекцию выдержанного пуэра с 1996 года.</span>
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">
            <span>Our family has been in the tea business for over 20 years. We started with a small shop in Kunming and grew to international supply. Over the years we have visited hundreds of tea farms, selected the best producers, and built a unique collection of aged puerh.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner CTA -->
  <section class="py-16 md:py-24 bg-[#1a1a1a] text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-4">
        <span class="text-white">Стать нашим партнёром</span>
        <span class="block text-orange-500 text-xl mt-1">Become Our Partner</span>
      </h2>
      <p class="text-gray-400 text-sm mb-8">
        <span>Мы всегда открыты к сотрудничеству с чайными магазинами, ресторанами, дистрибьюторами и частными марками.</span>
        <span class="block text-gray-500 mt-1">We are always open to cooperation with tea shops, restaurants, distributors and private labels.</span>
      </p>
      <CTAButton href="/contact">Связаться с нами <span class="text-gray-700 ml-1">| Contact Us</span></CTAButton>
    </div>
  </section>
</Layout>
