---
import Layout from "../../../components/Layout.astro";
import CTAButton from "../../../components/CTAButton.astro";
import { products, typeLabels, shapeLabels, getProductImg } from "../../../data/products";
import productDescriptions from "../../../data/product-descriptions.json";

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const p = products.find(x => x.slug === slug);

if (!p) return Astro.redirect("/404");

const descData = productDescriptions[p.slug] || {};
const hasDesc = descData.descRu || descData.descEn;

const productUrl = `/catalog/product/${p.slug}/`;
const productImg = getProductImg(p);
const origin = p.origin || "Yunnan";
const isGushu = p.treeAge === "gushu";
const treeAgeLabel = isGushu ? "100-500 years (gushu ancient trees)" : "40-100 years (arbor & plantation)";
const treeAgeLabelRu = isGushu ? "Гушу (100–500 лет)" : "Арбор (40–100 лет)";
const treeAgeLabelShort = isGushu ? "Gushu (100–500 yr)" : "Arbor (40–100 yr)";
const altitude = "1200–1800 m";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "PUERH DIRECT", item: "https://puerhdirect.ru/" },
    { "@type": "ListItem", position: 2, name: "Каталог | Catalog", item: "https://puerhdirect.ru/catalog/" },
    { "@type": "ListItem", position: 3, name: `${typeLabels[p.type].ru} | ${typeLabels[p.type].en}`, item: `https://puerhdirect.ru/catalog/${p.type === "raw" ? "raw-puerh" : "ripe-puerh"}/` },
    { "@type": "ListItem", position: 4, name: p.nameEn },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${p.year} ${p.nameEn} — ${typeLabels[p.type].en} ${shapeLabels[p.shape].en}`,
  description: `${p.year} ${typeLabels[p.type].en} ${shapeLabels[p.shape].en.toLowerCase()}, origin: ${origin} tea mountain, Yunnan, China. Altitude: ${altitude}. Tree age: ${treeAgeLabel}. Stored in Guangzhou warehouse at 20-25°C, 65-75% humidity for natural aging. Direct supply from producer, no middlemen.`,
  image: `https://puerhdirect.ru${productImg}`,
  category: `${typeLabels[p.type].en} Pu-erh Tea`,
  manufacturer: "PUERH DIRECT",
  brand: { "@type": "Brand", name: "PUERH DIRECT" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    offerCount: "1",
  },
  productionDate: `${p.year}`,
};
---

<Layout
  title={`${p.year} ${p.nameRu} | ${p.nameEn} — PUERH DIRECT`}
  description={hasDesc
    ? (descData.descRu || descData.descEn).slice(0, 160).replace(/\.[^.]*$/, '.')
    : `${p.year} ${typeLabels[p.type].ru} ${shapeLabels[p.shape].ru} «${p.nameRu}» — оптом из Гуанчжоу (Фанцунь). ${origin}, Юньнань. ${isGushu ? 'Гушу' : 'Арбор'}. MOQ 20 кг. ${p.year} ${p.nameEn} ${typeLabels[p.type].en} ${shapeLabels[p.shape].en} wholesale from Guangzhou Fangcun.`}
  ogImage={`https://puerhdirect.ru${productImg}`}
  canonicalURL={productUrl}
>
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-8">
        <a href="/catalog/" class="hover:text-orange-500 transition-colors">Каталог | Catalog</a>
        <span class="mx-2">/</span>
        <a href={`/catalog/${p.type === "raw" ? "raw-puerh" : "ripe-puerh"}/`} class="hover:text-orange-500 transition-colors">{typeLabels[p.type].ru} | {typeLabels[p.type].en}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-600">{p.nameEn}</span>
      </nav>

      <div class="grid md:grid-cols-2 gap-10 lg:gap-16">
        <div class="aspect-square rounded-2xl overflow-hidden bg-[#f5f5f5]">
          <img
            src={getProductImg(p)}
            alt={`${p.year} ${p.nameEn} — ${typeLabels[p.type].en} ${shapeLabels[p.shape].en}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-sm font-bold text-white bg-orange-500 px-3 py-1 rounded-full">{p.year}</span>
            <span class="text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-full">{typeLabels[p.type].ru} | {typeLabels[p.type].en}</span>
            <span class="text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-full">{shapeLabels[p.shape].ru} | {shapeLabels[p.shape].en}</span>
          </div>

          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            {p.nameRu}
          </h1>
          <p class="text-xl text-orange-500 font-medium mb-8">{p.nameEn}</p>

          <div class="space-y-4 text-gray-600 text-sm leading-relaxed mb-8">
            {hasDesc ? (
              <>
                <p class="text-gray-800 leading-relaxed">{descData.descRu || descData.descEn}</p>
                {descData.descEn && descData.descRu && (
                  <p class="text-gray-400 leading-relaxed">{descData.descEn}</p>
                )}
                {descData.descCn && (
                  <p class="text-gray-300 text-xs leading-relaxed border-t border-gray-100 pt-3 mt-3">
                    <span class="text-gray-400 font-medium">中文溯源 | Chinese Origin:</span> {descData.descCn}
                  </p>
                )}
              </>
            ) : (
              <>
                <p>
                  {p.year} года, {shapeLabels[p.shape].ru.toLowerCase()} пуэра. Происхождение: чайная гора {origin}, провинция Юньнань, Китай. Высота произрастания: {altitude}. Возраст деревьев: {treeAgeLabel}. Хранение на складе в Гуанчжоу (Фанцунь | Fangcun) при температуре 20–25°C и влажности 65–75%. Прямые поставки от производителя.
                </p>
                <p class="text-gray-400">
                  {p.year} {typeLabels[p.type].en} {shapeLabels[p.shape].en.toLowerCase()}. Origin: {origin} tea mountain, Yunnan, China. Altitude: {altitude}. Tree age: {treeAgeLabel}. Stored in Guangzhou warehouse (Fangcun tea market) at 20–25°C, 65–75% humidity. Direct supply from producer.
                </p>
              </>
            )}

          <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm border-t border-gray-100 pt-6 mb-8">
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Происхождение | Origin</dt>
              <dd class="text-gray-800 font-medium">{origin}, Yunnan, China</dd>
            </div>
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Высота | Altitude</dt>
              <dd class="text-gray-800 font-medium">{altitude}</dd>
            </div>
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Деревья | Trees</dt>
              <dd class="text-gray-800 font-medium">{treeAgeLabelRu}<span class="text-gray-400 ml-1">| {treeAgeLabelShort}</span></dd>
            </div>
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Хранение | Storage</dt>
              <dd class="text-gray-800 font-medium">Гуанчжоу, 20–25°C, 65–75% RH</dd>
            </div>
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Год | Year</dt>
              <dd class="text-gray-800 font-medium">{p.year} ({new Date().getFullYear() - p.year} лет выдержки | years aged)</dd>
            </div>
            <div class="flex flex-col gap-0.5">
              <dt class="text-xs text-gray-400 uppercase tracking-wide">Поставка | Supply</dt>
              <dd class="text-gray-800 font-medium">Напрямую от производителя | Direct</dd>
            </div>
          </dl>

          <div class="border-t border-gray-100 pt-8">
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="text-xs bg-orange-50 text-orange-600 px-3 py-1.5 rounded-full font-medium">MOQ: 20 кг | 20 kg</span>
              <span class="text-xs bg-gray-100 text-gray-500 px-3 py-1.5 rounded-full">Опт от 10 шт | Wholesale from 10 pcs</span>
              {p.origin && <span class="text-xs bg-gray-100 text-gray-500 px-3 py-1.5 rounded-full">{p.origin}, Yunnan</span>}
              {p.treeAge === "gushu" && <span class="text-xs bg-green-50 text-green-600 px-3 py-1.5 rounded-full font-medium">Гушу | Gushu</span>}
              <span class="text-xs bg-gray-100 text-gray-500 px-3 py-1.5 rounded-full">Фанцунь | Fangcun</span>
            </div>
            <p class="text-gray-500 text-sm mb-4">
              Заинтересованы в оптовых закупках? Свяжитесь с нами для получения прайс-листа.
              <span class="block text-gray-400 mt-1">Interested in wholesale? Contact us for a price list.</span>
            </p>
            <CTAButton href="/contact">Получить прайс | Get Quote</CTAButton>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)}></script>
</Layout>
