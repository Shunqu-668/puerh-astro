---
import Layout from "../../components/Layout.astro";
import CoverHero from "../../components/CoverHero.astro";
import { products, typeLabels, shapeLabels, getProductImg } from "../../data/products";

const rawProducts = products.filter(p => p.type === "raw");
---

<Layout
  title="Шэн Пуэр | Raw Puerh — PUERH DIRECT"
  description="Шэн пуэр (raw/sheng puerh) оптом из Китая. Натуральная ферментация, сложный вкус."
  ogImage="https://puerh-astro.pages.dev/images/images/2.jpg"
  canonicalURL="/catalog/raw-puerh/"
>
  <CoverHero
    titleRu="Шэн Пуэр"
    titleEn="Raw Puerh"
    subtitleRu="Естественная ферментация, сложный аромат, бодрящий эффект"
    subtitleEn="Natural fermentation, complex aroma, energizing effect"
    bgImage="/images/images/2.jpg"
  />
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {rawProducts.map(p => (
          <a href={`/catalog/product/${p.slug}/`} class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-orange-300 transition-all duration-300 block">
            <div class="aspect-square overflow-hidden bg-[#f5f5f5]">
              <img src={getProductImg(p)} alt={`${p.year} ${p.nameEn}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-bold text-white bg-orange-500 px-2 py-0.5 rounded">{p.year}</span>
                <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{typeLabels[p.type]?.ru} <span class="text-gray-400">| {typeLabels[p.type]?.en}</span></span>
              </div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">
                <span class="block">{p.nameRu}</span>
                <span class="block text-orange-500 text-xs font-medium mt-0.5">{p.nameEn}</span>
              </h3>
              <p class="text-xs text-gray-400">{shapeLabels[p.shape]?.ru} <span class="text-gray-300">|</span> <span class="text-gray-400">{shapeLabels[p.shape]?.en}</span></p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
