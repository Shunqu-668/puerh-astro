---
import Layout from "../components/Layout.astro";
import CoverHero from "../components/CoverHero.astro";
import CTAButton from "../components/CTAButton.astro";
---

<Layout
  title="Контакты | Contact Us — Свяжитесь для оптовых закупок пуэра"
  description="Свяжитесь с PUERH DIRECT для оптовых закупок пуэра из Гуанчжоу. Contact us for wholesale puerh from Guangzhou. Склад в Фанцунь, карго-доставка в РФ."
  ogImage="https://puerhdirect.ru/images/images/hero-contact.webp"
  canonicalURL="/contact/"
>
  <CoverHero
    titleRu="Контакты"
    titleEn="Contact Us"
    subtitleRu="Свяжитесь с нами для оптовых закупок. Всегда на связи."
    subtitleEn="Contact us for wholesale purchases. Always online for wholesale inquiries."
    bgImage="/images/images/hero-contact.webp"
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Telegram -->
        <a href="https://t.me/sqvivi777" target="_blank" rel="noopener noreferrer" class="group bg-[#f5f5f5] rounded-xl p-8 text-center hover:shadow-lg hover:bg-[#26A5E4] transition-all duration-300">
          <div class="w-16 h-16 bg-[#26A5E4] text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl group-hover:bg-white group-hover:text-[#26A5E4] transition-colors">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248c-.182 1.915-1.06 6.586-1.504 8.724-.184.986-.543 1.316-1.076 1.348-.933.086-1.64-.66-2.543-1.294-1.408-.99-2.208-1.61-3.575-2.583-.792-.56-.027-1.08.557-1.64.384-.37 2.6-2.54 2.648-2.757.006-.027.012-.13-.05-.184-.06-.054-.15-.036-.214-.02-.09.02-1.532.99-4.328 2.85-.41.28-.78.42-1.11.41-.364-.01-1.07-.21-1.595-.38-.642-.22-1.152-.34-1.107-.71.023-.2.29-.4.794-.6 3.13-1.36 5.215-2.26 6.256-2.69 2.98-1.24 3.6-1.45 4-1.46.09 0 .29.02.42.12.1.08.13.18.14.28.01.08.02.27 0 .42z"/></svg>
          </div>
          <h3 class="text-lg font-bold group-hover:text-white transition-colors">
            <span class="block text-gray-900 group-hover:text-white">Telegram</span>
          </h3>
          <p class="text-gray-500 text-sm group-hover:text-blue-100 transition-colors mt-2">@sqvivi777</p>
          <p class="text-gray-400 text-xs group-hover:text-blue-200 transition-colors mt-1">
            <span>Предпочтительный способ связи</span>
            <span class="block">Preferred contact method</span>
          </p>
        </a>

        <!-- WhatsApp -->
        <a href="https://wa.me/8613728005309" target="_blank" rel="noopener noreferrer" class="group bg-[#f5f5f5] rounded-xl p-8 text-center hover:shadow-lg hover:bg-[#25D366] transition-all duration-300">
          <div class="w-16 h-16 bg-[#25D366] text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl group-hover:bg-white group-hover:text-[#25D366] transition-colors">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <h3 class="text-lg font-bold group-hover:text-white transition-colors">
            <span class="block text-gray-900 group-hover:text-white">WhatsApp</span>
          </h3>
          <p class="text-gray-500 text-sm group-hover:text-green-100 transition-colors mt-2">+86-13728005309</p>
          <p class="text-gray-400 text-xs group-hover:text-green-200 transition-colors mt-1">
            <span>Быстрый ответ в чате</span>
            <span class="block">Quick chat response</span>
          </p>
        </a>

        <!-- WeChat -->
        <div class="bg-[#f5f5f5] rounded-xl p-8 text-center">
          <div class="w-16 h-16 bg-[#07C160] text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900">WeChat</h3>
          <p class="text-gray-500 text-sm mt-2">puerhdirect</p>
          <p class="text-gray-400 text-xs mt-1">
            <span>Отсканируйте QR-код</span>
            <span class="block">Scan QR code</span>
          </p>

        </div>

      </div>

      <!-- Address & MOQ -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[#f5f5f5] rounded-xl p-6 text-center">
          <h3 class="font-bold text-gray-900 mb-2">
            <span>Адрес склада</span>
            <span class="block text-orange-500 text-sm mt-0.5">Warehouse Address</span>
          </h3>
          <p class="text-gray-500 text-sm">
            <span>Склад в Гуанчжоу, Фанцунь</span>
            <span class="block text-gray-400 text-xs mt-1">Guangzhou Fangcun Tea Market, China</span>
          </p>
        </div>
        <div class="bg-[#f5f5f5] rounded-xl p-6 text-center">
          <h3 class="font-bold text-gray-900 mb-2">
            <span>Минимальный заказ</span>
            <span class="block text-orange-500 text-sm mt-0.5">Minimum Order</span>
          </h3>
          <p class="text-gray-500 text-sm">
            <span>Только опт. Минимальный заказ (MOQ): 20 кг</span>
            <span class="block text-gray-400 text-xs mt-1">Wholesale only. MOQ: 20 KG</span>
          </p>
        </div>
      </div>

      <!-- Inquiry CTA -->
      <div class="mt-16 bg-[#f5f5f5] rounded-2xl p-8 md:p-12">
        <h2 class="text-2xl font-bold mb-4 text-center">
          <span class="text-gray-900">Отправить запрос</span>
          <span class="block text-orange-500 text-lg mt-1">Send Inquiry</span>
        </h2>
        <p class="text-gray-500 text-sm mb-8 text-center max-w-lg mx-auto">
          <span>Заполните форму ниже, и мы свяжемся с вами в течение часа.</span>
          <span class="block text-gray-400 mt-1">Fill out the form below and we'll contact you within an hour.</span>
        </p>

        <form id="inquiry-form" action="https://api.web3forms.com/submit" method="POST" class="max-w-2xl mx-auto space-y-6">
          <input type="hidden" name="access_key" value="a1ae9002-3a5a-473b-8030-7559a8252650" />
          <input type="hidden" name="from_name" value="PUERH DIRECT — Контакты | Contact" />
          <input type="hidden" name="subject" value="Новый запрос с puerhdirect.ru" />
          <input type="hidden" name="redirect" value="false" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                Имя <span class="text-orange-500">*</span>
                <span class="text-gray-400 font-normal ml-1">| Name</span>
              </label>
              <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm" placeholder="Александр">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                Телефон / Контакт <span class="text-orange-500">*</span>
                <span class="text-gray-400 font-normal ml-1">| Phone / Contact</span>
              </label>
              <input type="text" name="contact" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm" placeholder="Telegram / WhatsApp / +7...">
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Электронная почта
              <span class="text-gray-400 font-normal ml-1">| Email</span>
              <span class="text-gray-400 text-xs ml-1">(необязательно | optional)</span>
            </label>
            <input type="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm" placeholder="your@email.com">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                Интересующий продукт
                <span class="text-gray-400 font-normal ml-1">| Product of Interest</span>
              </label>
              <select name="product_interest" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm text-gray-700">
                <option value="">Выберите из списка | Choose from list</option>
                <option value="shu-puerh">Шу Пуэр | Ripe Puerh</option>
                <option value="sheng-puerh">Шэн Пуэр | Raw Puerh</option>
                <option value="aged-puerh">Выдержанный пуэр (до 2005 г.) | Aged Puerh (pre-2005)</option>
                <option value="teaware">Чайная посуда | Teaware</option>
                <option value="private-label">Приватная марка | Private Label</option>
                <option value="other">Другое | Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                Предполагаемый объём
                <span class="text-gray-400 font-normal ml-1">| Estimated Volume</span>
              </label>
              <select name="order_volume" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm text-gray-700">
                <option value="">Выберите объём | Select volume</option>
                <option value="1-10">1-10 шт | pcs (проба | sample)</option>
                <option value="10-50">10-50 шт | pcs (мелкий опт | small wholesale)</option>
                <option value="50-200">50-200 шт | pcs (средний опт | medium wholesale)</option>
                <option value="200-1000">200-1000 шт | pcs (крупный опт | large wholesale)</option>
                <option value="1000+">1000+ шт | pcs (контейнер | container)</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Тип запроса <span class="text-orange-500">*</span>
              <span class="text-gray-400 font-normal ml-1">| Inquiry Type</span>
            </label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-300 cursor-pointer hover:border-orange-400 transition has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50">
                <input type="radio" name="inquiry_type" value="wholesale" checked class="w-4 h-4 text-orange-500 focus:ring-orange-500">
                <div>
                  <span class="text-sm font-medium text-gray-800">Оптовый заказ</span>
                  <span class="block text-xs text-gray-400">Wholesale Order</span>
                </div>
              </label>
              <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-300 cursor-pointer hover:border-orange-400 transition has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50">
                <input type="radio" name="inquiry_type" value="private_label" class="w-4 h-4 text-orange-500 focus:ring-orange-500">
                <div>
                  <span class="text-sm font-medium text-gray-800">Приватная марка / Изготовление под заказ</span>
                  <span class="block text-xs text-gray-400">Private Label / Customization</span>
                </div>
              </label>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Детали запроса
              <span class="text-gray-400 font-normal ml-1">| Inquiry Details</span>
            </label>
            <textarea name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition text-sm resize-y" placeholder="Опишите, какой чай вас интересует, желаемый объём, бюджет...&#10;Describe what tea you're interested in, desired volume, budget..."></textarea>
          </div>

          <div class="text-center pt-2">
            <button type="submit" id="submit-btn" class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-semibold rounded-lg transition-all duration-200 shadow-md hover:shadow-lg active:scale-[0.98] min-h-[44px] bg-[#F58220] text-gray-900 hover:bg-[#E07518] hover:shadow-orange-500/25">
              Отправить запрос <span class="text-gray-700 ml-1">| Send Inquiry</span>
            </button>
          </div>

          <div id="form-success" class="hidden text-center p-6 bg-green-50 rounded-xl border border-green-200">
            <p class="text-green-700 font-semibold text-lg">Запрос отправлен! | Inquiry Sent!</p>
            <p class="text-green-600 text-sm mt-1">Мы свяжемся с вами в ближайшее время. | We'll contact you shortly.</p>
          </div>

          <div id="form-error" class="hidden text-center p-6 bg-red-50 rounded-xl border border-red-200">
            <p class="text-red-700 font-semibold">Ошибка отправки | Submission Error</p>
            <p class="text-red-600 text-sm mt-1">Пожалуйста, попробуйте ещё раз или напишите нам в Telegram. | Please try again or contact us on Telegram.</p>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('inquiry-form');
  const btn = document.getElementById('submit-btn');
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerHTML = 'Отправка... | Sending...';
    success.classList.add('hidden');
    error.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        form.querySelectorAll('input:not([type=hidden]):not([type=radio]):not([type=checkbox]), textarea').forEach(el => el.value = '');
        form.querySelector('input[name=inquiry_type][value=wholesale]').checked = true;
        success.classList.remove('hidden');
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Отправить запрос <span class="text-gray-700 ml-1">| Send Inquiry</span>';
    }
  });
</script>
