---
import Layout from "../components/Layout.astro";
import CTAButton from "../components/CTAButton.astro";
import Picture from "../components/Picture.astro";

const categories = [
  { href: "/catalog/ripe-puerh", img: "/images/images/1.webp", ru: "Шу Пуэр", en: "Ripe Puerh" },
  { href: "/catalog/raw-puerh", img: "/images/images/2.webp", ru: "Шэн Пуэр", en: "Raw Puerh" },
  { href: "/catalog/teaware", img: "/images/images/3.webp", ru: "Чайники и Чабани", en: "Teapots & Tea Pets" },
  { href: "/catalog/other-tea", img: "/images/images/4.webp", ru: "Другой Чай", en: "Other Tea" },
];
---

<Layout
  title="Пуэр оптом из Гуанчжоу | Шу Пуэр / Шэн Пуэр"
  description="Прямые оптовые поставки пуэра с чайного рынка Фанцунь (Гуанчжоу). Шу Пуэр и Шэн Пуэр от 2006 года. Карго-доставка в РФ. Минимальный заказ 20 кг. Direct wholesale puerh from Guangzhou Fangcun. MOQ 20kg."
  ogImage="https://puerhdirect.ru/images/images/hero-bg.webp"
  canonicalURL="/"
>
  <link slot="head" rel="preload" as="image" href="/images/images/hero-bg.webp" fetchpriority="high" />

  <!-- ===== 1. HERO ===== -->
  <section class="relative h-[75vh] max-h-[700px] flex items-center justify-center" style="background-color: #1a1a1a; background-image: url('/images/images/hero-bg.webp'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-black/65 backdrop-blur-[3px]"></div>
    <div class="relative z-10 text-center text-white px-4 max-w-5xl mt-24">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">
        Шу Пуэр | Puerh Direct Wholesale
      </h1>
      <p class="text-lg text-gray-300 leading-relaxed max-w-4xl mx-auto mb-10">
        Direct from Fangcun, Guangzhou. 2nd Generation Tea Expert Selection. Карго-доставка в РФ (Серый ввоз) | Direct Cargo & Grey Customs Clearance.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <a href="/contact" class="px-8 py-4 text-sm font-bold tracking-widest uppercase bg-[#F58220] text-white rounded hover:bg-orange-600 transition">ПОЛУЧИТЬ ПРАЙС-ЛИСТ</a>
        <a href="/catalog" class="px-8 py-4 text-sm font-bold tracking-widest uppercase border-2 border-white text-white rounded hover:bg-white hover:text-black transition">В КАТАЛОГ</a>
      </div>
    </div>
  </section>

  <!-- ===== 2. 4-CATEGORY GRID ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {categories.map(cat => (
          <a href={cat.href} class="text-center group">
            <div class="w-32 h-32 md:w-48 md:h-48 mx-auto mb-4 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden group-hover:scale-105 transition-transform duration-300">
              <Picture src={cat.img} alt={cat.ru} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="font-bold text-lg mb-1">{cat.ru}</h3>
            <p class="text-sm text-gray-600">{cat.en}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 3. RARE TEA + CTA ===== -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">Редкие И Ценные Сорта Пуэра Со Склада В Гуанчжоу.</h2>
      <p class="text-xl text-gray-600 mb-8">Rare And Valuable Puer Varieties From Our Warehouse In Guangzhou.</p>
      <a href="/catalog" class="inline-block px-10 py-4 bg-[#F58220] text-white font-semibold rounded hover:bg-orange-600 transition">ALL PRODUCTS</a>
    </div>
  </section>

  <!-- ===== 4. GUANGZHOU ORIGIN + STATS ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">Прямо Из Гуанчжоу — Колыбели Чайной Культуры</h2>
        <p class="text-gray-600 mb-6">Directly From Guangzhou — The Cradle Of Tea Culture</p>
        <p class="text-gray-700 mb-8">Прямые закупки в Юньнани и профессиональное хранение на складах в Фанцунь, Гуанчжоу.</p>
        <div class="flex gap-8">
          <div>
            <div class="text-3xl font-bold text-[#F58220]">500+</div>
            <div class="text-sm text-gray-600">ОПТОВЫХ ПАРТНЕРОВ<br>WHOLESALE PARTNERS</div>
          </div>
        </div>
      </div>
      <div class="order-1 md:order-2">
        <Picture src="/images/images/fangcun-store.webp" alt="Склад Фанцунь" class="rounded-xl shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ===== 5. MISSION ===== -->
  <section class="py-24 text-center relative overflow-hidden" style="background-image: url('/images/images/mission-banner.webp'); background-size: cover; background-position: center; background-attachment: fixed; background-repeat: no-repeat;">
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 text-white">
      <p class="text-sm uppercase tracking-widest text-[#F58220] mb-4">НАША МИССИЯ | OUR MISSION</p>
      <h2 class="text-3xl md:text-5xl font-serif font-bold mb-6">Прямые Поставки Пуэра Из Гуанчжоу С 2006 Года</h2>
      <p class="text-xl text-gray-300">Direct Puerh Supply From Guangzhou Since 2006</p>
    </div>
  </section>

  <!-- ===== 6. EXPERTISE ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <Picture src="/images/images/expertise.webp" alt="Expertise" class="rounded-xl shadow-lg w-full" loading="lazy" />
      </div>
      <div>
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">Более 20 Лет Экспертизы В Отборе И Хранении Чая</h2>
        <p class="text-gray-600 mb-6">Over 20 Years Of Expertise In Tea Selection & Storage</p>
        <p class="text-gray-700 mb-8">Надежная логистика в Россию и СНГ. Гарантия сохранности и свежести каждой партии.</p>
        <a href="/about" class="inline-block px-10 py-4 bg-[#F58220] text-white font-semibold rounded hover:bg-orange-600 transition">ПОДРОБНЕЕ | LEARN MORE</a>
      </div>
    </div>
  </section>

  <!-- ===== 7. 3 VALUE PROPOSITIONS ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">Подлинный Чай Из Фанцунь Для Вашего Бизнеса</h2>
        <p class="text-gray-600 mb-6">Authentic Fangcun Tea For Your Business</p>
        <p class="text-gray-700 mb-8">Качественный пуэр оптом из первых рук.<br>Premium Wholesale Puerh from First Hands.</p>
        <div class="space-y-8">
          <div class="flex items-start gap-6">
            <span class="text-3xl font-bold text-[#F58220] tracking-tighter flex-shrink-0">01.</span>
            <div>
              <h3 class="font-bold text-lg mb-2">Прямые Поставки из Юньнани | Direct from Yunnan Factories</h3>
              <p class="text-sm text-gray-600">Собственные ресурсы в Мэнхай и Юндэ с 2006 года. Без посредников.</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <span class="text-3xl font-bold text-[#F58220] tracking-tighter flex-shrink-0">02.</span>
            <div>
              <h3 class="font-bold text-lg mb-2">Сухой Склад в Гуанчжоу | Guangzhou Dry Storage</h3>
              <p class="text-sm text-gray-600">Профессиональное хранение в Фанцунь. Идеальные условия для созревания пуэра.</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <span class="text-3xl font-bold text-[#F58220] tracking-tighter flex-shrink-0">03.</span>
            <div>
              <h3 class="font-bold text-lg mb-2">Контрактное Производство | Private Label (MOQ 20KG)</h3>
              <p class="text-sm text-gray-600">Изготовление под вашим брендом. Купаж малой партией от 20 кг.</p>
            </div>
          </div>
        </div>
      </div>
      <div>
        <Picture src="/images/images/value-prop.webp" alt="Value Proposition" class="rounded-xl shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ===== 8. PRICE / LOGISTICS ===== -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-8">
      <div class="text-center p-8 border border-gray-200 hover:border-[#F58220] transition-colors duration-300 bg-white">
        <h3 class="font-bold text-lg mb-3">Оптовый Прайс-лист | Wholesale Prices</h3>
        <p class="text-gray-600 text-sm">Запросите актуальный прайс-лист в Telegram. Только оптовые партии.</p>
      </div>
      <div class="text-center p-8 border border-gray-200 hover:border-[#F58220] transition-colors duration-300 bg-white">
        <h3 class="font-bold text-lg mb-3">Карго Логистика в РФ | Cargo Delivery to CIS</h3>
        <p class="text-gray-600 text-sm">Надежный "серый" ввоз (Карго). Оптимальные маршруты и сроки.</p>
      </div>
      <div class="text-center p-8 border border-gray-200 hover:border-[#F58220] transition-colors duration-300 bg-white">
        <h3 class="font-bold text-lg mb-3">Строгий Контроль | Strict QC</h3>
        <p class="text-gray-600 text-sm">Проверка каждой партии перед отгрузкой. Отправка только целыми коробками.</p>
      </div>
    </div>
  </section>

  <!-- ===== 9. TELEGRAM CHANNEL CTA ===== -->
  <section class="py-20 bg-[#1a1a1a] text-white">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-3xl font-serif font-bold mb-4">Закрытый Оптовый Telegram-Канал</h2>
        <p class="text-gray-300 mb-4">Private Wholesale Telegram Channel</p>
        <p class="text-gray-400 text-sm">Эксклюзивные предложения, остатки на складе в Гуанчжоу и видео с производства.</p>
      </div>
      <div class="flex justify-end">
        <a href="https://t.me/sqvivi777" class="px-10 py-5 bg-[#F58220] text-white font-bold uppercase tracking-widest rounded hover:bg-orange-600 transition inline-block">ПЕРЕЙТИ В TELEGRAM</a>
      </div>
    </div>
  </section>

</Layout>
