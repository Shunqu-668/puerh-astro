---
import Layout from "../components/Layout.astro";
import CoverHero from "../components/CoverHero.astro";
import CTAButton from "../components/CTAButton.astro";

const formats = [
  { img: "/images/images/shape-200g.webp", ru: "Стандартный блин 200 г", en: "Standard Cake 200g", descRu: "Классический формат пуэра, ходовой объём", descEn: "Classic puerh format, best-selling volume" },
  { img: "/images/images/shape-357g.webp", ru: "Блин 357 г", en: "Cake 357g", descRu: "Традиционный формат для выдержанного пуэра", descEn: "Traditional format for aged puerh" },
  { img: "/images/images/shape-500g.webp", ru: "Кирпич 500 г", en: "Brick 500g", descRu: "Популярный оптовый формат", descEn: "Popular wholesale format" },
  { img: "/images/images/shape-1000g.webp", ru: "Кирпич 1000 г", en: "Brick 1000g", descRu: "Крупный формат для оптовых партий", descEn: "Large format for wholesale batches" },
];

const workflow = [
  { step: "01", ru: "Консультация", en: "Consultation", descRu: "Выбор сырья и формата через Telegram.", descEn: "Select material and format via Telegram." },
  { step: "02", ru: "Образцы", en: "Samples", descRu: "Отправка тестовых образцов в РФ.", descEn: "Test samples shipped to Russia." },
  { step: "03", ru: "Производство", en: "Production", descRu: "Прессовка в Юньнани, упаковка в Фанцунь.", descEn: "Pressed in Yunnan, packed in Fangcun." },
  { step: "04", ru: "Логистика", en: "Logistics", descRu: "Отгрузка карго целыми коробками.", descEn: "Cargo shipping by full boxes." },
];
---

<Layout
  title="Контрактное Производство Пуэра | Private Label — MOQ 20 кг"
  description="Контрактное производство пуэра под вашим брендом. Изготовление блинов и кирпичей от 20 кг на собственных мощностях в Юньнани. Contract puerh manufacturing from 20 kg. Private label wholesale MOQ 20kg."
  ogImage="https://puerhdirect.ru/images/images/hero-private-label.webp"
  canonicalURL="/private-label/"
>
  <CoverHero
    titleRu="Контрактное Производство Пуэра"
    titleEn="Private Label Puerh Manufacturing"
    subtitleRu="Изготовление блинов и кирпичей под вашим брендом от 20 кг на собственных мощностях"
    subtitleEn="Custom cake and brick manufacturing under your brand from 20 kg at our own facilities"
    bgImage="/images/images/hero-private-label.webp"
  />

  <!-- Contract Manufacturing Solutions -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-4">
            <span class="text-gray-900">Контрактное Производство</span>
            <span class="block text-orange-500 text-xl mt-1">Contract Manufacturing</span>
          </h2>
          <p class="text-gray-500 text-sm mb-6">
            <span>Готовые рецепты или ваш уникальный купаж. Упаковка под вашим брендом в Гуанчжоу. Минимальный заказ — 20 кг.</span>
            <span class="block text-gray-400 mt-1">Ready recipes or your custom blend. Packed under your brand in Guangzhou. MOQ: 20 kg.</span>
          </p>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="text-orange-500 text-xl shrink-0 mt-0.5">✦</span>
              <div>
                <h4 class="font-semibold text-gray-900">Индивидуальная обёртка <span class="text-orange-500 font-normal text-sm">| Custom Wrapper</span></h4>
                <p class="text-gray-500 text-sm">Дизайн обёртки продукта с вашим брендом и логотипом <span class="text-gray-400">| Product wrapper design with your brand and logo</span></p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-orange-500 text-xl shrink-0 mt-0.5">◈</span>
              <div>
                <h4 class="font-semibold text-gray-900">Уникальный Купаж <span class="text-orange-500 font-normal text-sm">| Custom Blend Recipe</span></h4>
                <p class="text-gray-500 text-sm">Разработка вкуса под ваших клиентов. Купаж малой партией от 20 кг. <span class="text-gray-400">| Flavor development for your clients. Small-batch blending from 20 kg.</span></p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-orange-500 text-xl shrink-0 mt-0.5">◆</span>
              <div>
                <h4 class="font-semibold text-gray-900">Фирменная Упаковка <span class="text-orange-500 font-normal text-sm">| Branded Packaging</span></h4>
                <p class="text-gray-500 text-sm">Коробки, крафт-пакеты, премиум форматы — под ваш бренд <span class="text-gray-400">| Boxes, kraft bags, premium formats — all under your brand</span></p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-orange-500 text-xl shrink-0 mt-0.5">★</span>
              <div>
                <h4 class="font-semibold text-gray-900">Сертификаты и Документы <span class="text-orange-500 font-normal text-sm">| Certificates & Documentation</span></h4>
                <p class="text-gray-500 text-sm">Полный пакет документов на каждую партию для карго и таможни <span class="text-gray-400">| Full documentation for every batch — cargo and customs ready</span></p>
              </div>
            </li>
          </ul>
        </div>
        <div>
          <img src="/images/images/service-whitelabel.webp" alt="Contract Manufacturing Service" class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 4 B2B Formats -->
  <section class="py-16 md:py-24 bg-[#f5f5f5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-4">
        <span class="text-gray-900">Форматы для Оптового Производства</span>
        <span class="block text-orange-500 text-xl mt-1">Wholesale Production Formats</span>
      </h2>
      <p class="text-gray-500 text-center max-w-xl mx-auto mb-12 text-sm">
        <span>Стандартные форматы для контрактного производства. MOQ: 20 кг.</span>
        <span class="block text-gray-400 mt-1">Standard formats for contract manufacturing. MOQ: 20 kg.</span>
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {formats.map(f => (
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow">
            <div class="aspect-square overflow-hidden bg-[#f5f5f5]">
              <img src={f.img} alt={f.en} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-4 text-center">
              <h4 class="font-bold text-gray-900">{f.ru}<span class="block text-orange-500 text-sm font-medium mt-0.5">{f.en}</span></h4>
              <p class="text-gray-500 text-xs mt-2">{f.descRu}<span class="block text-gray-400 mt-0.5">{f.descEn}</span></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Blend -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <img src="/images/images/service-pressing.webp" alt="Custom Blend Production" class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" loading="lazy" />
        </div>
        <div>
          <h2 class="text-3xl font-bold mb-4">
            <span class="text-gray-900">Индивидуальный Купаж от 20 кг</span>
            <span class="block text-orange-500 text-xl mt-1">Custom Blend from 20 kg</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-3">
            <span>Индивидуальный купаж по вашему ТЗ. Прессовка в Юньнани, упаковка в Фанцунь. От 20 кг.</span>
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">
            <span>Custom blend to your specification. Pressed in Yunnan, packed in Fangcun. MOQ: 20 kg.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-Step Workflow -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-4">
        <span class="text-gray-900">Как мы работаем</span>
        <span class="block text-orange-500 text-xl mt-1">How We Work</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        {workflow.map(w => (
          <div class="text-center">
            <div class="w-16 h-16 bg-orange-500 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">{w.step}</div>
            <h4 class="font-bold text-gray-900 mb-2">{w.ru}<span class="block text-orange-500 text-sm font-medium mt-0.5">{w.en}</span></h4>
            <p class="text-gray-500 text-xs leading-relaxed">{w.descRu}<span class="block text-gray-400 mt-1">{w.descEn}</span></p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <CTAButton href="/contact">Начать проект <span class="text-gray-700 ml-1">| Start Project</span></CTAButton>
      </div>
    </div>
  </section>
</Layout>
